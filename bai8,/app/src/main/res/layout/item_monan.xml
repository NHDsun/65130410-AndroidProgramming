<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="50dp"
    android:layout_width="wrap_content"
    android:orientation="horizontal">
    <ImageView
        android:id="@+id/imanhDaiDien"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#157FB1"/>

    <LinearLayout
        android:layout_width="359dp"
        android:layout_height="50dp"
        android:background="#B2D1E9"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTenMonAn"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginLeft="5dp"
            android:text="Thịt xào dưa cải"
            android:textStyle="bold"
            android:textSize="16dp" />

        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginLeft="5dp"
            android:textStyle="italic"
            android:text="Thịt bò xào ta với dưa cải ngâm"
            android:textSize="10dp" />

        <TextView
            android:id="@+id/tvDonGia"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginLeft="5dp"
            android:text="20000 VNĐ"
            android:textStyle="normal"
            android:textSize="11dp" />

    </LinearLayout>
</LinearLayout>